#!/bin/bash
# pebble — build, install, run, and update the Pebble app.
#   ./pebble install    raw checkout → signed app in ~/Applications (+ this CLI on PATH)
#   pebble update       pull the latest from GitHub, rebuild, swap the live app
#   pebble run          launch the installed app
#   pebble test         run the golden test suite
set -euo pipefail

# resolve symlinks (the PATH install is a symlink to this script) so REPO is
# the real checkout, not the bin dir the symlink lives in
SRC="${BASH_SOURCE[0]}"
while [ -L "$SRC" ]; do
    SRC_DIR="$(cd "$(dirname "$SRC")" && pwd)"
    SRC="$(readlink "$SRC")"
    [[ "$SRC" != /* ]] && SRC="$SRC_DIR/$SRC"
done
REPO="$(cd "$(dirname "$SRC")" && pwd)"
APP_NAME="Pebble"
APP_DIR="$HOME/Applications"
APP="$APP_DIR/$APP_NAME.app"
# Pebble's source builds on Swift 6.0+ (Package.swift's floor; verified 6.0→6.3).
# If the user is below that, we offer to install this exact stable toolchain via
# swiftly and build with it — PEBBLE_SWIFT points the build at whatever we use.
SWIFT_FALLBACK="6.3.2"
PEBBLE_SWIFT="swift"
BOLD=$'\033[1m'; GREEN=$'\033[32m'; YELLOW=$'\033[33m'; RESET=$'\033[0m'

say()  { echo "${BOLD}${GREEN}==>${RESET}${BOLD} $*${RESET}"; }
warn() { echo "${BOLD}${YELLOW}warning:${RESET} $*"; }
die()  { echo "${BOLD}error:${RESET} $*" >&2; exit 1; }

# echoes the running Swift as "MAJOR MINOR", or nothing if it can't be parsed
swift_version() {
    swift --version 2>/dev/null | grep -oE 'version [0-9]+\.[0-9]+' | head -1 \
        | awk '{print $2}' | awk -F. '{print $1, $2}'
}

# install swiftly + Swift $SWIFT_FALLBACK into the user's home (no admin), then
# point the build at it. Every step here is the exact sequence swiftly documents.
install_swift_via_swiftly() {
    command -v curl >/dev/null 2>&1 || die "curl not found — can't fetch Swift automatically; update Xcode instead"
    local pkg; pkg="$(mktemp -t swiftly)" || die "mktemp failed"
    say "Downloading swiftly (Swift toolchain manager)…"
    curl -fsSL -o "$pkg.pkg" https://download.swift.org/swiftly/darwin/swiftly.pkg || die "swiftly download failed"
    installer -pkg "$pkg.pkg" -target CurrentUserHomeDirectory >/dev/null || die "swiftly install failed"
    rm -f "$pkg" "$pkg.pkg"
    local sw="$HOME/.swiftly/bin/swiftly"
    [ -x "$sw" ] || die "swiftly missing after install"
    export SWIFTLY_HOME_DIR="$HOME/.swiftly" SWIFTLY_BIN_DIR="$HOME/.swiftly/bin"
    "$sw" init --assume-yes --skip-install --no-modify-profile >/dev/null 2>&1 || true
    say "Installing Swift ${SWIFT_FALLBACK} (~1.6 GB, one time)…"
    "$sw" install "$SWIFT_FALLBACK" --assume-yes || die "Swift ${SWIFT_FALLBACK} install failed"
    # swiftly drops .0 patch numbers from the bundle name (6.3.0 -> swift-6.3-RELEASE)
    local tc bundle
    for bundle in "swift-${SWIFT_FALLBACK}-RELEASE" "swift-${SWIFT_FALLBACK%.0}-RELEASE"; do
        tc="$HOME/Library/Developer/Toolchains/$bundle.xctoolchain/usr/bin/swift"
        [ -x "$tc" ] && { PEBBLE_SWIFT="$tc"; break; }
    done
    [ -x "$PEBBLE_SWIFT" ] || die "couldn't locate the installed Swift ${SWIFT_FALLBACK}"
    say "Swift ${SWIFT_FALLBACK} ready."
}

need_swift() {
    # `command -v swift` always succeeds on macOS (the OS ships a shim), so
    # gate on the actual developer-tools install instead. No dev tools = no Swift
    # AND no macOS SDK; installing the CLT ships both (a current Swift + the SDK),
    # which swiftly alone can't provide — so this is the right call here.
    xcode-select -p >/dev/null 2>&1 || die "No Swift / developer tools found. Install Apple's command-line tools (this includes Swift):
       xcode-select --install
  then re-run:  ./pebble install"

    # Pebble needs Swift 6.0+ (Package.swift's tools-version; verified to build on
    # every 6.0→6.3 toolchain). Below that, SwiftPM bails with a cryptic manifest
    # error mid-install, so catch it up front and offer a clean way forward.
    local maj="" min=""
    read -r maj min < <(swift_version) || true   # empty/unparseable -> fall through to offer
    if [ -n "$maj" ] && { [ "$maj" -gt 6 ] || { [ "$maj" -eq 6 ] && [ "$min" -ge 0 ]; }; }; then
        return  # Swift 6.0+ — good to go
    fi

    local have="unknown"; [ -n "${maj:-}" ] && have="$maj.$min"
    warn "Pebble needs Swift 6.0 or newer — found: $have."
    echo "  Simplest fix: update Xcode (App Store) or the command-line tools, which ships a current Swift:"
    echo "      softwareupdate --all --install --force"
    echo
    echo "  Or install Swift ${SWIFT_FALLBACK} just for Pebble (via swiftly, into your home, no admin)."
    [ -t 0 ] || die "non-interactive shell — update Swift to 6.0+, then re-run: ./pebble install"
    printf "  Install Swift %s now? [y/N] " "$SWIFT_FALLBACK"
    local ans=""; read -r ans || true   # EOF/Ctrl-D -> empty -> treated as decline
    case "$ans" in
        y|Y|yes|YES) install_swift_via_swiftly ;;
        *) die "cancelled — update Swift to 6.0+ and re-run: ./pebble install" ;;
    esac
}

build() {
    say "Building Pebble (release)…"
    # not a terminal (CI, piped): plain passthrough
    if [ ! -t 1 ]; then
        (cd "$REPO" && "$PEBBLE_SWIFT" build -c release)
        return
    fi
    # release mode compiles the whole engine as one optimized unit and SwiftPM
    # prints nothing for minutes — spin so it doesn't look frozen
    local log; log="$(mktemp /tmp/pebble-build.XXXXXX)"
    (cd "$REPO" && "$PEBBLE_SWIFT" build -c release >"$log" 2>&1) &
    local pid=$!
    trap 'kill "$pid" 2>/dev/null; printf "\r\033[K"; exit 130' INT TERM
    local frames='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏' i=0 start=$SECONDS last=""
    while kill -0 "$pid" 2>/dev/null; do
        last="$(tail -n 1 "$log" 2>/dev/null | tr -d '\r')"
        printf '\r\033[K  %s%s%s %3ds  %.70s' "$GREEN" "${frames:$((i % 10)):1}" "$RESET" "$((SECONDS - start))" "${last:-warming up…}"
        i=$((i + 1))
        sleep 0.12
    done
    trap - INT TERM
    printf '\r\033[K'
    if wait "$pid"; then
        echo "  ${GREEN}✓${RESET} built in $((SECONDS - start))s"
        rm -f "$log"
    else
        cat "$log"
        rm -f "$log"
        die "build failed — full output above"
    fi
}

bundle() {
    say "Assembling $APP_NAME.app…"
    local stage="$REPO/dist/$APP_NAME.app"
    rm -rf "$stage"
    mkdir -p "$stage/Contents/MacOS" "$stage/Contents/Resources"
    cp "$REPO/packaging/Info.plist"     "$stage/Contents/Info.plist"
    cp "$REPO/packaging/AppIcon.icns"   "$stage/Contents/Resources/"
    # explicit list — only ship the assets the app actually loads
    cp "$REPO/packaging/logo.png"       "$stage/Contents/Resources/"
    cp "$REPO/packaging/title-bg.png"   "$stage/Contents/Resources/"
    cp "$REPO/packaging/"*.zip          "$stage/Contents/Resources/" 2>/dev/null || true
    # the Faithful license must travel with the pack (their requirement #6)
    cp "$REPO/packaging/FAITHFUL-LICENSE.txt" "$stage/Contents/Resources/" 2>/dev/null || true
    cp "$REPO/.build/release/Pebble"    "$stage/Contents/MacOS/Pebble"
    codesign --force --sign - "$stage" >/dev/null 2>&1 || warn "codesign failed — the app may trip Gatekeeper"
}

deploy() {
    say "Installing to ${APP} ..."
    mkdir -p "$APP_DIR"
    rm -rf "$APP"
    cp -R "$REPO/dist/$APP_NAME.app" "$APP"
}

link_cli() {
    for bin in /opt/homebrew/bin /usr/local/bin; do
        if [ -d "$bin" ] && [ -w "$bin" ]; then
            ln -sf "$REPO/pebble" "$bin/pebble"
            say "CLI linked: ${bin}/pebble → you can now run 'pebble update' from anywhere"
            return
        fi
    done
    warn "couldn't find a writable bin dir — run pebble via $REPO/pebble (or add it to your PATH)"
}

cmd_install() {
    need_swift
    build
    bundle
    deploy
    # drop the staging copy — Spotlight indexes it and you end up with
    # "two Pebbles" in Launchpad
    rm -rf "$REPO/dist"
    link_cli
    say "Done. Launch with:  pebble run   (or open ~/Applications/$APP_NAME.app)"
}

cmd_update() {
    [ -d "$REPO/.git" ] || die "$REPO is not a git checkout — 'pebble update' needs one (re-clone from GitHub, or just run: pebble install)"
    say "Pulling latest…"
    (cd "$REPO" && git pull --ff-only) || die "git pull failed — if you have local changes, commit/stash them; if upstream history changed, run: git fetch origin && git reset --hard origin/main"
    exec "$REPO/pebble" install
}

cmd_run()  { open "$APP" 2>/dev/null || die "Pebble isn't installed yet — run: pebble install"; }
cmd_test() { need_swift; (cd "$REPO" && "$PEBBLE_SWIFT" run -c release pebsmoke); }

case "${1:-}" in
    install) cmd_install ;;
    update)  cmd_update ;;
    run)     cmd_run ;;
    test)    cmd_test ;;
    *)
        echo "${BOLD}pebble${RESET} — one-command install for the Pebble app"
        echo
        echo "  ./pebble install    build from source and install ~/Applications/$APP_NAME.app"
        echo "  pebble update       pull the latest version and update the live app"
        echo "  pebble run          launch Pebble"
        echo "  pebble test         run the golden test suite"
        ;;
esac
